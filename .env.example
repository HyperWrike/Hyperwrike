# =====================================================================
# Hyperwrike environment variables
# Copy this file to `.env.local` and fill in real values.
# Never commit real keys to git — `.env.local` is gitignored.
# =====================================================================

# --- Brevo (transactional email for contact form) ---
BREVO_API_KEY=xkeysib-REPLACE_ME
BREVO_SENDER_EMAIL=team@hyperwrike.com
BREVO_SENDER_NAME=Hyperwrike
BREVO_NOTIFICATION_INBOX=team@hyperwrike.com

# --- Groq (AI chatbot) ---
GROQ_API_KEY=gsk_REPLACE_ME
GROQ_MODEL=llama-3.3-70b-versatile

# --- Server ---
SERVER_PORT=8787
